<h1>Place Details</h1>

<p>
  <strong>Name:</strong>
  <%= @place.name %>
</p>

<% @entries.each do |entry| %>
  <h3><%= entry["title"] %></h3>
  <p><%= entry["occurred_on"] %></p>
  <p><%= entry["description"] %></p>
<% end %>


<p>
  <a href= "/entries/new?place_id=<%= @place["id"] %>">New Entry</a>
</p>
<p><%= link_to "Back to Places", places_path %></p>